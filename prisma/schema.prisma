generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  icon      String     @default("📦")
  prices    Price[]
  cartItems CartItem[]
}

model Store {
  id        Int        @id @default(autoincrement())
  name      String
  url       String     @default("")
  prices    Price[]
  cartItems CartItem[]
}

model Price {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  store     Store   @relation(fields: [storeId], references: [id])
  storeId   Int
  price     Int
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  searches  Search[]
  cartItems CartItem[]
}

model Search {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  query     String
  createdAt DateTime @default(now())
}

model CartItem {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   Int
  price     Int
  addedAt   DateTime @default(now())
}
