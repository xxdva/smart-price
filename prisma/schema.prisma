generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  icon       String      @default("📦")
  imageUrl   String      @default("")
  prices     Price[]
  cartItems  CartItem[]
  reviews    Review[]
  orderItems OrderItem[]
}

model Store {
  id         Int           @id @default(autoincrement())
  name       String
  url        String        @default("")
  prices     Price[]
  cartItems  CartItem[]
  ratings    StoreRating[]
  orderItems OrderItem[]
}

model Price {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  store     Store   @relation(fields: [storeId], references: [id])
  storeId   Int
  price     Int
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  searches     Search[]
  cartItems    CartItem[]
  reviews      Review[]
  storeRatings StoreRating[]
  addresses    Address[]
  paymentCards PaymentCard[]
  orders       Order[]
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String
  city      String   @default("Алматы")
  street    String
  house     String
  apartment String   @default("")
  lat       Float    @default(0)
  lng       Float    @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  orders    Order[]
}

model PaymentCard {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  last4       String
  cardType    String   @default("visa")
  expiryMonth Int
  expiryYear  Int
  holder      String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  addressId  Int
  address    Address     @relation(fields: [addressId], references: [id])
  cardId     Int
  card       PaymentCard @relation(fields: [cardId], references: [id])
  status     String      @default("paid")
  totalPrice Int
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  storeId   Int
  store     Store   @relation(fields: [storeId], references: [id])
  price     Int
  name      String
}

model Review {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  rating    Int
  text      String
  createdAt DateTime @default(now())
  @@unique([productId, userId])
}

model StoreRating {
  id        Int      @id @default(autoincrement())
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  rating    Int
  createdAt DateTime @default(now())
  @@unique([storeId, userId])
}

model Search {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  query     String
  createdAt DateTime @default(now())
}

model CartItem {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   Int
  price     Int
  addedAt   DateTime @default(now())
}
